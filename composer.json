{
    "name": "eril/auth",
    "description": "Simple PHP authentication and authorization library with sessions, remember-me and role based permissions.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "auth",
        "authentication",
        "authorization",
        "rbac",
        "permissions",
        "session",
        "login",
        "php"
    ],
    "authors": [
        {
            "name": "Eril Tavares",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-pdo": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Eril\\Auth\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Eril\\Auth\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/auth"
    ],
    "minimum-stability": "stable",
    "prefer-stable": true
}